# ------------------------------------------------------------------
# Copy to .env.local and fill in.  Never commit .env.local.
# ------------------------------------------------------------------

# Neon Postgres (free tier)
POSTGRES_URL=postgres://user:pass@host/db?sslmode=require
POSTGRES_URL_UNPOOLED=postgres://user:pass@host/db?sslmode=require

# Payload — 32+ char random; generate with `openssl rand -hex 32`
PAYLOAD_SECRET=

# Public site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Cloudflare R2 (free: 10 GB storage + unlimited egress)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=av-portfolio-media
R2_PUBLIC_URL=https://cdn.example.com

# Mux (optional — only for breakdown / process videos)
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=

# Resend — contact form relay (free: 3K emails/mo)
RESEND_API_KEY=
CONTACT_TO_EMAIL=

# Admin creation (scripts/create-admin.ts reads these)
ADMIN_EMAIL=
ADMIN_PASSWORD=
